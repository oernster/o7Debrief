[flake8]
# Match black's line length and disable the two checks that conflict with
# black's formatting: E203 (whitespace before ':') and W503 (line break before
# a binary operator). Both are black-correct but flake8-default-noisy.
max-line-length = 88
extend-ignore = E203, W503
# Skip the virtualenv, caches and build artefacts so `flake8 .` is clean.
exclude =
    .git,
    __pycache__,
    .pytest_cache,
    venv,
    build,
    dist,
    dist-installer,
    *.build,
    *.dist,
    *.onefile-build,
    *.egg-info
